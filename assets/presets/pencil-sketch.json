{
	"name": "Pencil sketch",
	"description": "Classic pencil sketch effect. Common in old photo editing tools.",
	"pipeline": [
		{
			"filter": "sobel",
			"params": {
				"greyscale": true
			}
		},
		{
			"filter": "linearAdjustment",
			"params": {
				"scale": 2,
				"offset": -0.155
			}
		},
		{
			"filter": "invert"
		},
		{
			"filter": "blur",
			"params": {
				"size": 5
			}
		}
	],
	"output_suffix": "_processed",
	"output_extension": "auto"
}
